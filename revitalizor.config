{
  "$doc": "Config du Revitalizor. JSON = données pures (ne modifie rien tout seul, lu par revitalizor.js).",
  "arena": { "initialBytes": 65536, "growFactor": 2 },
  "compactThreshold": 0.25,
  "integrity": { "autoHash": true, "algo": "SHA-256" },
  "transfer": { "chunkBytes": 1048576, "resumable": true },
  "autoCycleMs": 5000,
  "polarities": {
    "+": "Fractal-Collé — bloc actif copié, génère du PAWA",
    "-": "Vide-Compressé — corps d'octets supprimé du live, fantôme gardé",
    "~": "Superposé-Guérisseur — patch de guérison (heal) d'un bloc corrompu"
  }
}
